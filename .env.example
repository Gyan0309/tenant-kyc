AUTH_SECRET=replace-with-random-secret
NEXTAUTH_SECRET=replace-with-random-secret

# Use a real Azure Storage connection string, or an Azurite connection string for local development.
AZURE_TABLE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=replace-with-azurite-or-azure-key;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1;
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=replace-with-azurite-or-azure-key;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

AZURE_BLOB_CONTAINER_DOCS=tenant-documents
AZURE_BLOB_CONTAINER_ASSETS=property-assets
