{
  "name": "tenant-manager",
  "version": "0.1.0",
  "private": true,
  "author": "SAGA",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "gen:icon": "node scripts/generate-icon.mjs",
    "build:desktop": "next build && node scripts/postbuild-standalone.mjs",
    "desktop": "electron electron/main.js",
    "dist": "npm run build:desktop && electron-builder",
    "dist:dir": "npm run build:desktop && electron-builder --dir"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/storage-blob": "^12.31.0",
    "@base-ui/react": "^1.4.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "mupdf": "^1.28.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.saga.propertysuite",
    "productName": "Tenant Manager",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build-resources"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Tenant Manager"
    }
  }
}
